# Bearcamp environment — copy to `.env` for local dev. Never commit `.env`.

# ---- Postgres ----------------------------------------------------------------
# WS-2 supports two backends behind the same Prisma client (see lib/db/prisma.ts):
#   * Docker Postgres (default; works with `docker compose up -d`).
#   * Neon serverless (auto-detected by `.neon.tech` host; uses the HTTP driver,
#     review-2 DR-10).
# `DATABASE_URL` is the pooled URL used by the app at runtime.
# `DIRECT_URL` is the unpooled URL used by `prisma migrate` only.

# Default — local Docker Postgres (see docker-compose.yml).
DATABASE_URL="postgresql://bearcamp:bearcamp@localhost:5432/bearcamp"
DIRECT_URL="postgresql://bearcamp:bearcamp@localhost:5432/bearcamp"

# Neon example (preview / production). The host's `.neon.tech` suffix is
# detected automatically and the Neon HTTP adapter is selected.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ---- App config --------------------------------------------------------------
# Storage backend selector consumed by lib/services.ts (WS-0). Defaults to
# `memory` (in-memory fake + fixtures). Set to `prisma` once WS-8 wires it
# end to end.
BEARCAMP_BACKEND="memory"

# CSRF origin pin for Server Actions (WS-8, next.config.ts —
# `experimental.serverActions.allowedOrigins`). Comma-separated list of
# origins allowed to invoke Server Actions when `NODE_ENV=production`.
# Ignored in dev. Set this to your deployment host(s) before going live.
BEARCAMP_ALLOWED_ORIGINS="https://your-host.example.com"

# Optional — RIDB (Recreation.gov) API key used only by the WS-3 importer
# script (`pnpm tsx scripts/import-ridb.ts`) to refresh data/campsites.seed.json.
# Not consumed at runtime; leave unset unless you are reseeding the catalog.
# RIDB_API_KEY=""

# Optional — if the Next dev server is running, `prisma db seed` will ping
# `${BC_DEV_URL}/api/revalidate-campsites` to refresh the cached catalog
# (review-3 DR-50 / DR-57). Leave unset for CLI / CI seed runs.
# BC_DEV_URL="http://localhost:3000"
