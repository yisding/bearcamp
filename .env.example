# Bearcamp environment — copy to `.env` for local dev. Never commit `.env`.

# Neon Postgres connection strings (pooled + direct). See plan/local-dev.md.
# Pooled — runtime app queries (Prisma + @prisma/adapter-neon).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Direct (unpooled) — `prisma migrate` only.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Storage backend selector. Defaults to `memory` (in-memory fake +
# fixtures). Set to `prisma` once WS-2 is wired.
BEARCAMP_BACKEND="memory"
